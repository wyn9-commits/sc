EVALUATE TOPN(10,SUMMARIZECOLUMNS('Billing File'[Facility Name],'Billing File'[Country],"Cost",SUM('Billing File'[Allocated USD])),[Cost],DESC)

Note: Operating expense uses Billing File table with [Country] column not [Country Name].


